---
import { getCollection } from 'astro:content';

const reasons = await getCollection('reasons');
const sortedReasons = reasons.sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const badgeColors = [
  "bg-accent text-ink",
  "bg-terracotta text-paper",
  "bg-ink text-paper",
  "bg-paper text-ink border border-ink"
];
---

<section id="reasons" class="py-24 bg-paper border-b border-ink relative overflow-hidden paper-texture">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <!-- セクション見出し -->
    <div class="mb-20 text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-ink/10 pb-8">
      <div class="space-y-2">
        <span class="font-hand text-2xl text-terracotta block">Why Chosen</span>
        <h2 class="font-serif font-extrabold text-3xl md:text-4xl text-ink">
          選ばれる4つの理由
        </h2>
      </div>
    </div>

    <!-- アシンメトリーなカードレイアウト (偶数カードを少し下げる) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12" id="reasons-grid">
      {sortedReasons.map((reason, index) => {
        // 段違いにするためのマージン適用
        const offsetClass = index % 2 === 1 ? "md:translate-y-8" : "";
        const badgeColor = badgeColors[index % badgeColors.length];

        return (
          <div 
            class={`reason-card p-6 sm:p-8 md:p-10 border-2 border-ink bg-paper relative shadow-[6px_6px_0px_#1c1c1c] transition-all duration-300 hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] ${offsetClass}`}
            data-index={index}
          >
            <!-- 左上の手書き風ステップバッジ -->
            <div class={`absolute top-[-15px] left-6 font-hand text-xl font-bold px-3 py-1 border-2 border-ink shadow-[2px_2px_0px_#1c1c1c] ${badgeColor}`}>
              Reason 0{index + 1}
            </div>

            <div class="space-y-4 pt-4">
              <!-- 各カードに固有の手書き風アイコンを表示 -->
              <div class="w-12 h-12 text-terracotta shrink-0">
                {index === 0 && (
                  <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15,20 C35,18 65,18 85,20 C87,35 87,60 85,75 C65,77 35,77 15,75 C13,60 13,35 15,20 Z" />
                    <path d="M15,32 C35,31 65,31 85,32" />
                    <circle cx="23" cy="26" r="2.5" fill="currentColor" />
                    <circle cx="31" cy="26" r="2.5" fill="currentColor" />
                    <circle cx="39" cy="26" r="2.5" fill="currentColor" />
                    <path d="M42,52 C45,46 55,46 58,52 C55,58 45,58 42,52 Z" />
                    <circle cx="50" cy="52" r="3.5" fill="currentColor" />
                    <path d="M72,40 L74,36 L78,35 L74,34 L72,30 L70,34 L66,35 L70,36 Z" fill="currentColor" opacity="0.6" />
                  </svg>
                )}
                {index === 1 && (
                  <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M50,15 C69,15 85,31 85,50 C85,69 69,85 50,85 C31,85 15,69 15,50 C15,31 31,15 50,15 Z" />
                    <path d="M50,22 C65,22 78,35 78,50 C78,65 65,78 50,78 C35,78 22,65 22,50 C22,35 35,22 50,22 Z" stroke-dasharray="3 4" />
                    <path d="M38,36 L50,52 L62,36" />
                    <path d="M50,52 L50,70" />
                    <path d="M42,56 L58,56" />
                    <path d="M42,62 L58,62" />
                  </svg>
                )}
                {index === 2 && (
                  <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18,52 L82,18 L58,82 L48,58 Z" />
                    <path d="M82,18 L48,58" />
                    <path d="M48,58 L42,72 L38,58" />
                    <path d="M12,78 C22,74 30,76 35,80" stroke-dasharray="2 3" />
                    <path d="M22,86 C28,84 34,85 38,88" stroke-dasharray="2 3" />
                  </svg>
                )}
                {index === 3 && (
                  <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M50,85 C50,85 78,56 78,36 C78,20 65,13 50,13 C35,13 22,20 22,36 C22,56 50,85 50,85 Z" />
                    <path d="M42,32 C42,29 46,26 50,30 C54,26 58,29 58,32 C58,36 50,42 50,42 C50,42 42,36 42,32 Z" fill="currentColor" />
                    <path d="M12,68 C25,60 45,72 65,62 C75,57 82,60 88,65" opacity="0.5" />
                    <path d="M35,62 L35,80" opacity="0.5" stroke-dasharray="2 2" />
                    <path d="M65,65 L65,85" opacity="0.5" stroke-dasharray="2 2" />
                  </svg>
                )}
              </div>

              <h3 class="font-serif font-extrabold text-xl md:text-2xl text-ink leading-tight">
                {reason.data.title}
              </h3>
              
              <div class="text-xs md:text-sm text-ink-light leading-relaxed font-sans pt-2 whitespace-pre-wrap">
                {reason.body}
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- 段違いレイアウトの余白確保用のスペース -->
    <div class="h-8 hidden md:block"></div>

  </div>
</section>

<script>
  // GSAPによるスクロールフェードイン
  const grid = document.getElementById('reasons-grid');

  if (grid) {
    const observer = new IntersectionObserver(async (entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        observer.unobserve(grid);

        try {
          const { default: gsap } = await import('gsap');
          
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            gsap.from('.reason-card', {
              opacity: 0,
              y: 50,
              duration: 0.8,
              stagger: 0.2,
              ease: 'power3.out',
              onStart: function() {
                gsap.set('.reason-card', { transition: 'none' });
              },
              onComplete: function() {
                gsap.set('.reason-card', { clearProps: "transition,opacity,transform" });
              }
            });
          }
        } catch (error) {
          console.error('Failed to load GSAP in Reasons section:', error);
        }
      }
    }, { rootMargin: '100px' });

    observer.observe(grid);
  }
</script>
