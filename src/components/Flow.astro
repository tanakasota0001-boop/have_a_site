---
import { getCollection } from "astro:content";

const flowSteps = await getCollection("flow");
const sortedFlowSteps = flowSteps.sort(
  (a, b) => a.data.sortOrder - b.data.sortOrder,
);
---

<section
  id="flow"
  class="py-24 bg-paper border-b border-ink relative overflow-hidden paper-texture"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <!-- セクション見出し -->
    <div class="text-center space-y-4 mb-16">
      <span class="font-hand text-3xl text-terracotta block">Flow</span>
      <h2
        class="font-serif font-extrabold text-3xl md:text-4xl text-ink leading-tight"
      >
        ホームページ完成までの流れ
      </h2>
    </div>

    <!-- ステップリスト (横並び) -->
    <div
      class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-8 relative"
      id="flow-steps-container"
    >
      {
        sortedFlowSteps.map((step, index) => {
          return (
            <div class="relative group">
              {/* デスクトップ用：ステップ間の矢印コネクタ */}
              {index < sortedFlowSteps.length - 1 && (
                <div class="hidden md:block absolute top-1/2 left-[calc(100%_+_4px)] -translate-y-1/2 z-20 pointer-events-none">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 text-ink/30"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </div>
              )}

              {/* ステップカード */}
              <div class="flow-card h-full p-6 border-2 border-ink bg-paper relative shadow-[6px_6px_0px_#1c1c1c] transition-all hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] duration-300 flex flex-col justify-between">
                <div>
                  {/* ステップ番号バッジ */}
                  <div class="flex items-center justify-between mb-4">
                    <span class="font-hand text-3xl font-bold text-terracotta">
                      0{index + 1}
                    </span>
                    <span class="font-serif text-[10px] text-ink/40 tracking-widest uppercase font-bold">
                      {step.data.step}
                    </span>
                  </div>

                  <div class="space-y-3">
                    <h3 class="font-serif font-extrabold text-lg md:text-xl text-ink pb-2 border-b border-ink/10">
                      {step.data.title}
                    </h3>
                    <div class="text-xs md:text-sm text-ink-light leading-relaxed font-sans whitespace-pre-wrap">
                      {step.body.trim()}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  // GSAP ScrollTrigger による進行アニメーション
  const flowContainer = document.getElementById("flow-steps-container");

  if (flowContainer) {
    const observer = new IntersectionObserver(
      async (entries) => {
        const entry = entries[0];
        if (entry.isIntersecting) {
          observer.unobserve(flowContainer);

          try {
            const { default: gsap } = await import("gsap");
            const { ScrollTrigger } = await import("gsap/ScrollTrigger");

            gsap.registerPlugin(ScrollTrigger);

            if (
              !window.matchMedia("(prefers-reduced-motion: reduce)").matches
            ) {
              // 各ステップカードのフェードイン・スライド
              gsap.from(".flow-card", {
                opacity: 0,
                y: 30,
                duration: 0.8,
                stagger: 0.15,
                ease: "power2.out",
                scrollTrigger: {
                  trigger: flowContainer,
                  start: "top 80%",
                },
              });
            }
          } catch (error) {
            console.error("Failed to load GSAP in Flow section:", error);
          }
        }
      },
      { rootMargin: "100px" },
    );

    observer.observe(flowContainer);
  }
</script>
