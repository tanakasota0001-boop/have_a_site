---
const problems = [
  {
    id: "prob-1",
    tag: "Q. 01",
    text: "ホームページは欲しいけれど、何から始めればいいか全く分からない。",
    rotation: "rotate-[-2deg]",
    bg: "bg-[#FEF08A] text-ink", // 付箋イエロー
  },
  {
    id: "prob-2",
    tag: "Q. 02",
    text: "制作会社に依頼すると、高額な見積もりを出されそうで不安…。",
    rotation: "rotate-[3deg]",
    bg: "bg-[#FED7AA] text-ink", // 付箋オレンジ
  },
  {
    id: "prob-3",
    tag: "Q. 03",
    text: "日々の仕事が忙しくて、ホームページの準備まで手が回らない！",
    rotation: "rotate-[-1.5deg]",
    bg: "bg-[#BAE6FD] text-ink", // 付箋ブルー
  },
  {
    id: "prob-4",
    tag: "Q. 04",
    text: "パソコンやWebのことが苦手。公開後の更新や管理ができるか心配。",
    rotation: "rotate-[2.5deg]",
    bg: "bg-[#E9D5FF] text-ink", // 付箋パープル
  },
];
---

<section id="problems" class="py-24 bg-paper relative overflow-hidden paper-texture">

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    
    <!-- セクション見出し -->
    <div class="text-center space-y-4 mb-20">
      <span class="font-hand text-2xl text-terracotta block">Troubles & Concerns</span>
      <h2 class="font-serif font-extrabold text-3xl md:text-4xl text-ink leading-tight">
        こんなお悩み、ありませんか？
      </h2>
    </div>

    <!-- お悩みのグリッド (ノートに付箋を貼ったようなデザイン) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-3xl mx-auto" id="problems-grid">
      {problems.map((prob) => (
        <div 
          class={`problem-sticky p-6 border-2 border-ink ${prob.bg} ${prob.rotation} shadow-[4px_4px_0px_#1c1c1c] transition-transform duration-300 hover:rotate-0 flex flex-col justify-between aspect-auto min-h-[160px] sm:aspect-[1.4/1] relative`}
          id={prob.id}
        >
          <!-- 角のテープ風装飾（エディトリアル） -->
          <div class="absolute top-[-10px] left-1/2 -translate-x-1/2 w-12 h-5 bg-paper/60 border border-ink/20 rotate-[5deg] backdrop-blur-[2px]"></div>

          <div class="space-y-3">
            <div class="flex items-center">
              <span class="w-7 h-7 border-2 border-ink flex items-center justify-center text-lg font-extrabold text-terracotta bg-white rounded-[4px] shadow-[2px_2px_0px_#1c1c1c] transform -rotate-[4deg]">
                ✓
              </span>
            </div>
            <p class="font-serif font-bold text-base md:text-lg text-ink leading-relaxed">
              {prob.text}
            </p>
          </div>

        </div>
      ))}
    </div>

    <!-- 下部への導線 (解決へ) -->
    <div class="mt-20 flex flex-col items-center justify-center text-center">
      <p class="font-serif font-extrabold text-xl md:text-2xl text-ink tracking-wide">
        <span class="marker-highlight-terracotta px-3 py-1">そのお悩み、私たちに任せてください</span>
      </p>
    </div>

  </div>
</section>

<script>
  // IntersectionObserver + GSAPで付箋がばらまかれるアニメーション
  const gridContainer = document.getElementById('problems-grid');

  if (gridContainer) {
    const observer = new IntersectionObserver(async (entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        observer.unobserve(gridContainer);

        try {
          const { default: gsap } = await import('gsap');
          
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            // 付箋が上から回転しながら落ちてくるようなアニメーション
            gsap.from('.problem-sticky', {
              opacity: 0,
              scale: 0.8,
              y: 80,
              rotation: () => (Math.random() - 0.5) * 15,
              duration: 1,
              stagger: 0.25,
              ease: 'back.out(1.5)',
              onStart: function() {
                gsap.set('.problem-sticky', { transition: 'none' });
              },
              onComplete: function() {
                gsap.set('.problem-sticky', { clearProps: "transition,opacity,transform" });
              }
            });
          }
        } catch (error) {
          console.error('Failed to load GSAP in Problems section:', error);
        }
      }
    }, { rootMargin: '100px' });

    observer.observe(gridContainer);
  }
</script>
