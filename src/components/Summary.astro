---
const features = [
  {
    num: "01",
    label: "初期費用",
    title: "初期費用0円",
    desc: "サーバーやドメインの取得、初期デザイン設計にかかる制作費はすべて0円。初期投資を抑えてスタートできます。"
  },
  {
    num: "02",
    label: "安心お試し",
    title: "ご契約前に無料サンプル確認",
    desc: "相談後に動くサンプルを作成するため、完成イメージに納得してから契約するか判断できます。無駄なリスクはありません。"
  },
  {
    num: "03",
    label: "運用おまかせ",
    title: "制作・更新はほぼ丸投げOK",
    desc: "掲載したい情報をお送りいただくだけで、その後のページ構成や更新、エラー対応までこちらで一括管理します。"
  }
];
---

<section id="summary" class="py-24 border-t border-b border-ink bg-paper relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <!-- タイトルとマガジン風ライン -->
    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="space-y-2">
        <span class="font-hand text-3xl text-terracotta block">Introductory Features</span>
        <h2 class="font-serif font-extrabold text-3xl md:text-4xl text-ink leading-tight">
          はじめてでも安心の3つのポイント
        </h2>
      </div>
    </div>

    <!-- 特徴レイアウト (雑誌のグリッド崩し) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8 relative" id="features-container">
      
      <!-- 各カード -->
      {features.map((feat, index) => (
        <div 
          class="feature-card flex flex-col p-8 border-2 border-ink bg-paper relative shadow-[4px_4px_0px_#1c1c1c] transition-all duration-300 hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px]"
          data-index={index}
        >
          <!-- 装飾的な背景数字 -->
          <div class="absolute right-4 top-2 font-hand text-6xl text-accent/20 select-none z-0 pointer-events-none">
            {feat.num}
          </div>

          <div class="space-y-6 relative z-10">
            <!-- 小ラベル -->
            <span class="inline-block text-[10px] font-bold tracking-wider px-2 py-0.5 border border-ink/30 text-ink/60 bg-paper uppercase">
              {feat.label}
            </span>

            <div class="space-y-3">
              <h3 class="font-serif font-bold text-xl md:text-2xl text-ink leading-tight">
                {feat.title}
              </h3>
              <p class="text-xs md:text-sm text-ink-light leading-relaxed font-sans">
                {feat.desc}
              </p>
            </div>
          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<script>
  // スクロールフェードインアニメーションをGSAPの動的インポートで実装（遅延ロード）
  const featuresContainer = document.getElementById('features-container');

  if (featuresContainer) {
    const observer = new IntersectionObserver(async (entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        observer.unobserve(featuresContainer);

        // GSAP & ScrollTrigger の遅延ロード
        try {
          const { default: gsap } = await import('gsap');
          
          // prefers-reduced-motion をチェック
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            gsap.from('.feature-card', {
              opacity: 0,
              y: 50,
              duration: 0.8,
              stagger: 0.2,
              ease: 'power3.out'
            });
          }
        } catch (error) {
          console.error('Failed to load GSAP in Summary section:', error);
        }
      }
    }, { rootMargin: '100px' }); // 画面に入る少し前に読み込み開始

    observer.observe(featuresContainer);
  }
</script>
