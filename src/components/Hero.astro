---
// Hero.astro (外枠を完全に排除し、画像自体にホバーアニメーションを直接適用して空白を完全解消したFV)
---

<section
  class="relative overflow-hidden paper-texture min-h-[550px] lg:h-screen flex flex-col justify-center pt-28 pb-16 lg:pt-32 lg:pb-20"
>
  <!-- アクリル画風抽象アートの背景レイヤー (不透明度を48%に緩和し、若干薄くして上品に) -->
  <div
    class="absolute inset-0 pointer-events-none select-none z-0 overflow-hidden"
  >
    <div
      class="w-full h-full absolute inset-0 bg-cover bg-center bg-no-repeat opacity-[0.48] animate-fluid-bg"
      style="background-image: url('/assets/acrylic_art_bg.png');"
    >
    </div>
  </div>

  <!-- 背景を程よく透かし、極太明朝体テキストが完璧に読める透過紙色オーバーレイ (不透明度45%に調整) -->
  <div class="absolute inset-0 bg-paper/45 pointer-events-none z-[1]"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
      <!-- 左：文字コンテンツ (7カラム、左揃え) -->
      <div
        class="lg:col-span-7 flex flex-col items-start text-left space-y-6 md:space-y-8"
      >
        <!-- 1. タグラベル -->
        <div
          class="inline-block px-4 py-1.5 border border-ink text-[10px] md:text-xs font-bold tracking-widest uppercase bg-paper shadow-[2px_2px_0px_#1c1c1c] rotate-[-1.5deg] select-none z-20"
        >
          個人店・小規模事業者 専門
        </div>

        <!-- 2. メインコピー (3行の改行構成とアクセント。紙色ふち影で高い可読性を維持) -->
        <h1
          class="font-serif font-extrabold text-ink leading-[1.3] md:leading-[1.2] flex flex-col items-start drop-shadow-[0_2px_12px_rgba(253,251,247,0.98)] z-20"
        >
          <!-- 1行目: あなたのお店の -->
          <span
            class="block text-2xl md:text-4xl lg:text-5xl font-normal text-ink/90 mb-1.5"
          >
            あなたのお店の
          </span>

          <!-- 2行目: ホームページ (手書き丸囲み付き) -->
          <span
            class="relative inline-block px-5 py-2 my-1 text-3xl sm:text-4xl md:text-6xl lg:text-7xl text-terracotta rotate-[-1.5deg] origin-left scale-[1.03] transition-transform duration-300 hover:rotate-0"
          >
            ホームページ
            <!-- 手書きの丸で囲むSVG -->
            <svg
              class="absolute left-[-2%] top-[-5%] w-[104%] h-[110%] text-accent pointer-events-none z-[-1] hand-draw-svg"
              viewBox="0 0 100 100"
              preserveAspectRatio="none"
              id="hero-circle-svg"
            >
              <path
                d="M10,50 C10,20 90,15 90,50 C90,80 15,85 10,55 C8,45 25,35 60,35"
                stroke="currentColor"
                stroke-width="2.5"
                fill="none"
                stroke-linecap="round"></path>
            </svg>
          </span>

          <!-- 3行目: 無料でみてみませんか？ -->
          <span class="block text-2xl sm:text-3xl md:text-5xl lg:text-6xl mt-1.5 leading-tight">
            <span class="inline-block">無料で</span><span class="inline-block">みてみませんか？</span>
          </span>
        </h1>

        <!-- 3. サブコピー (エディトリアル装飾線を添えて) -->
        <div
          class="flex items-center space-x-3 select-none drop-shadow-[0_1px_6px_rgba(253,251,247,0.98)] z-20"
        >
          <p
            class="font-serif font-bold text-sm md:text-xl text-terracotta tracking-wider"
          >
            塩尻市・松本市のHP制作屋さん
          </p>
          <div class="w-10 h-[1.5px] bg-terracotta/30"></div>
        </div>

        <!-- 4. CTAエリア -->
        <div class="w-full sm:w-auto pt-2 z-20">
          <a
            href="#contact"
            class="group w-full sm:w-auto inline-block text-center bg-terracotta text-paper font-serif font-bold text-sm md:text-base tracking-widest px-10 py-4 border-2 border-ink shadow-[3px_3px_0px_#1c1c1c] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] transition-all duration-200"
          >
            無料サンプルを相談する
            <span
              class="inline-block transition-transform group-hover:translate-x-1 duration-200 ml-2"
              >→</span
            >
          </a>
        </div>
      </div>

      <!-- 右：イラストコンテンツ (5カラム、外枠コンテナを完全に排除し、画像自体がホバー時に拡大・移動するように直接定義) -->
      <div class="lg:col-span-5 flex justify-center lg:justify-end z-10">
        <img
          src="/assets/pop_handdrawn_browser.png"
          alt="手書き風のポップで可愛いブラウザ型ホームページイラスト"
          class="w-full max-w-[440px] md:max-w-[530px] lg:max-w-[560px] h-auto transition-all duration-300 ease-out hover:scale-[1.03] hover:-translate-y-1 cursor-pointer select-none"
          id="hero-illustration-card"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* アクリル背景パターンの微細な平行移動アニメーション */
  @keyframes fluidPan {
    0% {
      transform: translate(0px, 0px) rotate(0deg);
    }
    50% {
      transform: translate(8px, -4px) rotate(0.3deg);
    }
    100% {
      transform: translate(0px, 0px) rotate(0deg);
    }
  }

  .animate-fluid-bg {
    animation: fluidPan 22s infinite ease-in-out;
  }

  /* ユーザーがOSでアニメーション制限を設定している場合はアニメーションを停止 */
  @media (prefers-reduced-motion: reduce) {
    .animate-fluid-bg {
      animation: none !important;
      transform: none !important;
    }
    #hero-illustration-card:hover {
      transform: none !important;
    }
  }
</style>

<script>
  // IntersectionObserver を使用して手書き丸囲みアニメーションを発火
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 },
  );

  const circleSvg = document.getElementById("hero-circle-svg");
  if (circleSvg) {
    observer.observe(circleSvg);
  }
</script>
