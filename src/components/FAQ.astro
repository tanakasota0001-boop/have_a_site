---
import { getCollection } from 'astro:content';

const faqs = await getCollection('faq');
const sortedFaqs = faqs.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section id="faq" class="py-24 bg-paper border-b border-ink relative overflow-hidden paper-texture">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <!-- セクション見出し -->
    <div class="text-center space-y-4 mb-20">
      <span class="font-hand text-2xl text-terracotta block">FAQ</span>
      <h2 class="font-serif font-extrabold text-3xl md:text-4xl text-ink leading-tight">
        よくある質問
      </h2>
    </div>

    <!-- アコーディオン (details / summary) -->
    <div class="space-y-4 max-w-3xl mx-auto" id="faq-list">
      {sortedFaqs.map((faq, index) => (
        <details 
          class="group border-2 border-ink bg-paper p-5 md:p-6 transition-all duration-300 shadow-[4px_4px_0px_#1c1c1c] open:shadow-none open:translate-x-[4px] open:translate-y-[4px] faq-item"
          data-index={index}
        >
          <summary class="flex items-center justify-between cursor-pointer list-none focus:outline-none select-none">
            <div class="flex items-center space-x-4">
              <span class="font-hand text-2xl text-terracotta font-bold shrink-0">Q.</span>
              <h3 class="font-serif font-bold text-sm md:text-base text-ink leading-tight">
                {faq.data.question}
              </h3>
            </div>
            
            <!-- 開閉用矢印 (手書き風) -->
            <span class="w-6 h-6 rounded-full border border-ink flex items-center justify-center font-bold text-ink shrink-0 group-open:rotate-180 transition-transform duration-200">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
              </svg>
            </span>
          </summary>
          
          <div class="mt-4 pt-4 border-t border-ink/10 flex items-start space-x-4">
            <span class="font-hand text-2xl text-accent font-bold shrink-0">A.</span>
            <div class="text-xs md:text-sm text-ink-light leading-relaxed font-sans pt-1">
              {faq.body.trim()}
            </div>
          </div>
        </details>
      ))}
    </div>

  </div>
</section>

<script>
  // GSAPによるスクロールフェードイン
  const faqList = document.getElementById('faq-list');

  if (faqList) {
    const observer = new IntersectionObserver(async (entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        observer.unobserve(faqList);

        try {
          const { default: gsap } = await import('gsap');
          
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            gsap.from('.faq-item', {
              opacity: 0,
              y: 30,
              duration: 0.6,
              stagger: 0.1,
              ease: 'power2.out',
              onStart: function() {
                gsap.set('.faq-item', { transition: 'none' });
              },
              onComplete: function() {
                gsap.set('.faq-item', { clearProps: "transition,opacity,transform" });
              }
            });
          }
        } catch (error) {
          console.error('Failed to load GSAP in FAQ section:', error);
        }
      }
    }, { rootMargin: '100px' });

    observer.observe(faqList);
  }
</script>
