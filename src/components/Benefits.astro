---
import { getCollection } from 'astro:content';

const benefits = await getCollection('benefits');
const sortedBenefits = benefits.sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<section id="benefits" class="py-24 bg-paper border-b border-ink relative paper-texture">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      
      <!-- 左側：セクション見出し（PCでは追従してスクロールする誌面見出し風） -->
      <div class="lg:col-span-5 lg:sticky lg:top-32 lg:pr-12 lg:border-r-2 lg:border-dashed lg:border-ink/20 pb-8 lg:pb-0">
        <div class="benefits-header-content space-y-4 text-center lg:text-left">
          <span class="font-hand text-3xl md:text-4xl text-terracotta block">
            User Action Change
          </span>
          <h2 class="font-serif font-extrabold text-3xl md:text-4xl text-ink leading-tight lg:leading-[1.4]">
            ホームページがあると、<br class="hidden lg:block" />お客様の行動が<br class="hidden lg:block" />変わります
          </h2>
        </div>
      </div>

      <!-- 右側：メリットのリスト -->
      <div class="lg:col-span-7 space-y-16" id="benefits-list">
        {sortedBenefits.map((benefit, index) => {
          const badgeBg = index % 2 === 0 ? "bg-accent text-ink" : "bg-terracotta text-paper";
          return (
            <div class="benefit-item relative p-6 sm:p-8 md:p-10 border-2 border-ink bg-paper shadow-[6px_6px_0px_#1c1c1c] rounded-sm transition-all duration-300 hover:shadow-[2px_2px_0px_#1c1c1c] hover:translate-x-[4px] hover:translate-y-[4px] benefits-card-grid">
              <!-- インデックスフォルダ風のタブバッジ -->
              <div class={`absolute -top-[30px] left-6 border-2 border-b-0 border-ink font-hand text-base md:text-lg font-bold px-4 py-0.5 rounded-t-md ${badgeBg} shadow-[1px_0px_0px_rgba(0,0,0,0.05)]`}>
                Benefit 0{index + 1}
              </div>
              
              <div class="space-y-4">
                <h3 class="font-serif font-extrabold text-xl md:text-2xl text-ink leading-tight">
                  {benefit.data.title}
                </h3>
                
                <div class="text-xs md:text-sm text-ink-light leading-relaxed font-sans pt-1">
                  {benefit.body}
                </div>
              </div>
            </div>
          );
        })}
      </div>

    </div>

  </div>
</section>

<script>
  const benefitsSection = document.getElementById('benefits');
  const list = document.getElementById('benefits-list');

  if (benefitsSection && list) {
    const observer = new IntersectionObserver(async (entries) => {
      const entry = entries[0];
      if (entry.isIntersecting) {
        observer.unobserve(benefitsSection);

        try {
          const { default: gsap } = await import('gsap');
          const { ScrollTrigger } = await import('gsap/ScrollTrigger');
          
          gsap.registerPlugin(ScrollTrigger);

          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            // 1. 左側キャッチコピーのスムーズなスクロール追従（遅延・パララックス）
            const headerContent = document.querySelector('.benefits-header-content');
            if (headerContent && window.matchMedia('(min-width: 1024px)').matches) {
              gsap.to(headerContent, {
                y: 120, // スクロールに伴って120pxほどスムーズに遅れて追従する
                ease: 'none',
                scrollTrigger: {
                  trigger: '#benefits',
                  start: 'top 20%',
                  end: 'bottom 80%',
                  scrub: 1.2, // スクロール量に追いつくまでの遅延時間
                }
              });
            }

            // 2. 右側メリット項目の順次フェードイン
            gsap.from('.benefit-item', {
              opacity: 0,
              y: 60,
              duration: 1,
              stagger: 0.3,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: list,
                start: 'top 80%',
              }
            });
          }
        } catch (error) {
          console.error('Failed to load GSAP in Benefits section:', error);
        }
      }
    }, { rootMargin: '200px' });

    observer.observe(benefitsSection);
  }
</script>

<style>
  .benefits-card-grid {
    background-image: 
      linear-gradient(rgba(28, 28, 28, 0.03) 1px, transparent 1px), 
      linear-gradient(90deg, rgba(28, 28, 28, 0.03) 1px, transparent 1px);
    background-size: 16px 16px;
  }
</style>
